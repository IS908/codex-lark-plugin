# === Required ===
LARK_APP_ID=
LARK_APP_SECRET=

# === Optional — Filtering ===
# LARK_ALLOWED_USER_IDS=         # Sender open_id whitelist, comma-separated
# LARK_ALLOWED_CHAT_IDS=         # Chat ID whitelist, comma-separated

# === Optional — Messaging ===
# LARK_TEXT_CHUNK_LIMIT=4000     # Max chars per text chunk
# LARK_QUEUE_HANDLER_TIMEOUT_MS=660000 # 0 disables; lower positive values are raised to LARK_CODEX_EXEC_TIMEOUT_MS + 60000
# LARK_REPLY_OBLIGATION_TIMEOUT_MS=660000 # Max wait for a visible reply/defer before logging a missed Lark turn
# LARK_CODEX_EXEC_COMMAND=codex
# LARK_CODEX_EXEC_CWD=                   # Default: ~/.codex/channels/lark/codex-exec-workdir
# LARK_CODEX_EXEC_TIMEOUT_MS=600000
# LARK_CODEX_EXEC_SANDBOX=workspace-write # read-only | workspace-write | danger-full-access
# LARK_CODEX_EXEC_MODEL=
# LARK_CODEX_EXEC_PROFILE=
# LARK_CODEX_EXEC_IGNORE_USER_CONFIG=true # Prevent recursive loading of this Lark MCP server
# LARK_CODEX_EXEC_USE_SESSIONS=true       # Resume one Codex exec session per Feishu chat/thread
# LARK_EXEC_PROGRESS_ENABLED=true         # Send bounded progress updates during long-running visible codex exec turns
# LARK_EXEC_PROGRESS_MAX_MESSAGES=3       # Max progress messages per codex exec turn
# LARK_EXEC_PROGRESS_MAX_CHARS=300        # Max chars per progress message
# LARK_EXEC_PROGRESS_MIN_INTERVAL_MS=15000 # Minimum interval between progress messages in one turn
# LARK_EXEC_PROGRESS_POLL_INTERVAL_MS=250 # Parent watcher polling interval for progress JSONL
# LARK_CODEX_EXEC_TOOL_TRACE=false        # Write local codex exec tool-call trace JSONL records to trace.log
# LARK_CODEX_EXEC_TOOL_TRACE_MODE=compact # compact | full | hidden
# LARK_CODEX_EXEC_TRACE_LOG=              # Trace JSONL log path (default: ~/.codex/channels/lark/trace.log)
# LARK_CODEX_SESSION_RETENTION_DAYS=14    # Keep Codex exec resume-pointer records newer than this many days
# LARK_CODEX_SESSION_RETENTION_SCAN_INTERVAL_HOURS=24 # Set 0 to disable automatic cleanup
# LARK_CODEX_SESSION_RETENTION_DRY_RUN=false # Preview cleanup candidates without deleting session records
# LARK_SESSION_HEALTH_ENABLED=false       # Opt-in long-running codex exec session health nudges to owner DM
# LARK_SESSION_HEALTH_TURN_THRESHOLD=80
# LARK_SESSION_HEALTH_PROMPT_BYTES_THRESHOLD=524288 # Heuristic prompt bytes; Codex exec exposes no stable context usage stat
# LARK_SESSION_HEALTH_TOKEN_THRESHOLD=160000 # Token threshold when Codex exec JSONL usage is available
# LARK_SESSION_HEALTH_IDLE_DELAY_MS=30000
# LARK_SESSION_HEALTH_COOLDOWN_MS=1800000
# LARK_SESSION_HEALTH_MAX_COOLDOWN_MS=21600000
# LARK_SESSION_HEALTH_MAX_NUDGES=3

# === Optional — Acknowledgement ===
# LARK_ACK_EMOJI=MeMeMe                # Emoji reaction on message receive. Set empty to disable.
# LARK_DOC_COMMENT_ACK_EMOJI=THUMBSUP  # Persistent emoji reaction on inbound doc-comment mentions. Set empty to disable.
# LARK_BOT_MESSAGE_TRACKER_SIZE=500    # Max bot-sent message IDs tracked for passive reaction-event filtering (FIFO)

# === Optional — Feishu API reliability ===
# LARK_FEISHU_API_TIMEOUT_MS=30000       # Per Feishu API call timeout
# LARK_FEISHU_API_RETRY_ATTEMPTS=3       # Attempts for retryable transient Feishu/API/network failures
# LARK_FEISHU_API_RETRY_BASE_DELAY_MS=250 # Exponential backoff base delay
# LARK_DOWNLOAD_MAX_BYTES=26214400       # Max bytes for downloaded attachments/images
# LARK_DOWNLOAD_TIMEOUT_MS=60000         # Attachment/image download timeout

# === Optional — CronJob ===
# LARK_CRON_SCAN_INTERVAL=60           # Scheduler scan interval in seconds
# LARK_CRON_TIMEZONE=                  # IANA timezone for cron schedule evaluation (default: system tz, e.g. Asia/Shanghai)

# === Optional — Memory ===
# LARK_MIN_SEARCH_SCORE=0.3     # Minimum relevance score for episode search
# LARK_MAX_SEARCH_RESULTS=2     # Max episodes per query
# LARK_INACTIVITY_HOURS=3       # Auto-flush trigger threshold
# LARK_MAX_EPISODE_BYTES=65536  # Max bytes per episode file before truncation
# LARK_MAX_EPISODE_FILES_PER_SCOPE=200      # Max episode files per chat/thread scope
# LARK_MAX_EPISODE_SCOPE_BYTES=10485760     # Max total episode bytes per chat/thread scope
# LARK_PROFILE_DISTILLATION_ENABLED=false   # Distill recent episodes into tiered profiles
# LARK_PROFILE_DISTILLATION_MIN_EPISODES=3  # Min episodes before profile distillation can dispatch
# LARK_PROFILE_DISTILLATION_MAX_EPISODES=5  # Max recent episodes included in one distillation prompt
# LARK_PROFILE_DISTILLATION_COOLDOWN_MS=86400000 # Per-user profile distillation cooldown
# LARK_MEMORY_DEDUP_WINDOW_MS=1800000       # Suppress unchanged memory blocks per chat/thread for 30m. Set 0 to disable.

# === Optional — Identity / privacy (v0.9.0+) ===
# LARK_OWNER_OPEN_ID=            # Operator open_id — enables terminal skills like /lark:jobs
# LARK_IDENTITY_SESSION_TTL_MS=  # Session entry TTL in ms (default: max(2h, inactivity × 2))
# LARK_IDENTITY_SESSION_MAX_ENTRIES=5000    # Max server-derived caller session entries
# LARK_PRIVACY_RULES_FILE=       # L2 user rules file path (default: ~/.codex/channels/lark/privacy-rules.md)
# LARK_AUDIT_LOG=                # Audit JSONL log path (default: ~/.codex/channels/lark/audit.log)
# LARK_LOCAL_CLI_TOOLS_CONFIG=   # Local CLI allowlist config (default: ~/.codex/channels/lark/local-cli-tools.json)
# LARK_GITHUB_ISSUE_TIMEOUT_MS=30000       # Timeout for built-in GitHub HTTP issue creation
# LARK_GITHUB_API_BASE_URL=https://api.github.com # GitHub API base URL for built-in proposal filing
# LARK_GITHUB_TOKEN=                       # Token for built-in GitHub HTTP issue creation; GH_TOKEN/GITHUB_TOKEN also work
# LARK_CARD_CONTEXT_CACHE_SIZE=200         # Cached fetched-card parent/root contexts
# LARK_CARD_CONTEXT_CACHE_TTL_MS=1800000   # TTL for fetched-card context cache
# LARK_QUOTED_CONTEXT_MAX_DEPTH=4          # Max quoted/replied message chain depth before prompting Codex
# LARK_QUOTED_CONTEXT_MAX_BYTES=12000      # UTF-8 byte budget for hydrated quoted-message context
# LARK_QUOTED_CARD_USER_FETCH_ENABLED=true       # Fallback to lark-cli --as user when bot identity cannot hydrate quoted cards
# LARK_QUOTED_CARD_USER_FETCH_COMMAND=lark-cli   # lark-cli executable for quoted-card user fallback
# LARK_QUOTED_CARD_USER_FETCH_TIMEOUT_MS=10000   # Timeout for quoted-card user fallback
# LARK_QUOTED_CARD_USER_FETCH_MAX_BYTES=262144   # Max stdout/stderr bytes captured from quoted-card user fallback

# === Optional — Resource governance ===
# LARK_DEBUG_LOG=                # Debug log path (default: ~/.codex/channels/lark/debug.log)
# LARK_LOG_MAX_BYTES=5242880    # Rotate debug/audit/trace logs after this many bytes
# LARK_LOG_MAX_FILES=5          # Number of rotated log files to keep
# LARK_INBOX_MAX_AGE_HOURS=168  # Delete inbox downloads older than this during startup cleanup
# LARK_INBOX_MAX_BYTES=209715200 # LRU cap for inbox downloads during startup cleanup
# LARK_NAME_CACHE_SIZE=1000     # Max cached Feishu user/chat display names
# LARK_CHAT_TYPE_CACHE_SIZE=1000 # Max cached Feishu chat types
# LARK_LATEST_MESSAGE_TRACKER_SIZE=1000 # Max latest-inbound message tracker entries
