# === Required ===
LARK_APP_ID=
LARK_APP_SECRET=

# === Optional — Filtering ===
# LARK_ALLOWED_USER_IDS=         # Sender open_id whitelist, comma-separated
# LARK_ALLOWED_CHAT_IDS=         # Chat ID whitelist, comma-separated

# === Optional — Messaging ===
# LARK_TEXT_CHUNK_LIMIT=4000     # Max chars per text chunk
# LARK_QUEUE_HANDLER_TIMEOUT_MS=30000
# LARK_CODEX_DELIVERY_MODE=exec          # exec | notification. exec runs codex exec and replies directly.
# LARK_CODEX_EXEC_COMMAND=codex
# LARK_CODEX_EXEC_CWD=                   # Default: plugin process cwd
# LARK_CODEX_EXEC_TIMEOUT_MS=600000
# LARK_CODEX_EXEC_SANDBOX=workspace-write # read-only | workspace-write | danger-full-access
# LARK_CODEX_EXEC_MODEL=
# LARK_CODEX_EXEC_PROFILE=
# LARK_CODEX_EXEC_IGNORE_USER_CONFIG=true # Prevent recursive loading of this Lark MCP server
# LARK_CODEX_EXEC_USE_SESSIONS=true       # Resume one Codex exec session per Feishu chat/thread

# === Optional — Acknowledgement ===
# LARK_ACK_EMOJI=MeMeMe                # Emoji reaction on message receive. Set empty to disable.
# LARK_DOC_COMMENT_ACK_EMOJI=THUMBSUP  # Persistent emoji reaction on inbound doc-comment mentions. Set empty to disable.
# LARK_BOT_MESSAGE_TRACKER_SIZE=500    # Max bot-sent message IDs tracked for passive reaction-event filtering (FIFO)

# === Optional — Feishu API reliability ===
# LARK_FEISHU_API_TIMEOUT_MS=30000       # Per Feishu API call timeout
# LARK_FEISHU_API_RETRY_ATTEMPTS=3       # Attempts for retryable transient Feishu/API/network failures
# LARK_FEISHU_API_RETRY_BASE_DELAY_MS=250 # Exponential backoff base delay
# LARK_DOWNLOAD_MAX_BYTES=26214400       # Max bytes for downloaded attachments/images
# LARK_DOWNLOAD_TIMEOUT_MS=60000         # Attachment/image download timeout

# === Optional — CronJob ===
# LARK_CRON_SCAN_INTERVAL=60           # Scheduler scan interval in seconds
# LARK_CRON_TIMEZONE=                  # IANA timezone for cron schedule evaluation (default: system tz, e.g. Asia/Shanghai)

# === Optional — Memory ===
# LARK_MIN_SEARCH_SCORE=0.3     # Minimum relevance score for episode search
# LARK_MAX_SEARCH_RESULTS=2     # Max episodes per query
# LARK_INACTIVITY_HOURS=3       # Auto-flush trigger threshold
# LARK_MAX_EPISODE_BYTES=65536  # Max bytes per episode file before truncation
# LARK_MAX_EPISODE_FILES_PER_SCOPE=200      # Max episode files per chat/thread scope
# LARK_MAX_EPISODE_SCOPE_BYTES=10485760     # Max total episode bytes per chat/thread scope
# LARK_MEMORY_DEDUP_WINDOW_MS=1800000       # Suppress unchanged memory blocks per chat/thread for 30m. Set 0 to disable.

# === Optional — Identity / privacy (v0.9.0+) ===
# LARK_OWNER_OPEN_ID=            # Operator open_id — enables terminal skills like /lark:jobs
# LARK_IDENTITY_SESSION_TTL_MS=  # Session entry TTL in ms (default: max(2h, inactivity × 2))
# LARK_IDENTITY_SESSION_MAX_ENTRIES=5000    # Max server-derived caller session entries
# LARK_PRIVACY_RULES_FILE=       # L2 user rules file path (default: ~/.codex/channels/lark/privacy-rules.md)
# LARK_AUDIT_LOG=                # Audit log path (default: ~/.codex/channels/lark/audit.log)

# === Optional — Resource governance ===
# LARK_DEBUG_LOG=                # Debug log path (default: ~/.codex/channels/lark/debug.log)
# LARK_LOG_MAX_BYTES=5242880    # Rotate debug/audit logs after this many bytes
# LARK_LOG_MAX_FILES=5          # Number of rotated log files to keep
# LARK_INBOX_MAX_AGE_HOURS=168  # Delete inbox downloads older than this during startup cleanup
# LARK_INBOX_MAX_BYTES=209715200 # LRU cap for inbox downloads during startup cleanup
# LARK_NAME_CACHE_SIZE=1000     # Max cached Feishu user/chat display names
# LARK_CHAT_TYPE_CACHE_SIZE=1000 # Max cached Feishu chat types
# LARK_LATEST_MESSAGE_TRACKER_SIZE=1000 # Max latest-inbound message tracker entries
